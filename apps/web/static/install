#!/bin/sh
# JioBase Self-Host Installer
# https://jiobase.com/install
#
# Usage:
#   curl -fsSL https://jiobase.com/install | sh
#
# This script:
#   1. Checks for Node.js >= 18
#   2. Installs Node.js via fnm if missing
#   3. Runs `npx create-jiobase` to scaffold & deploy
#
set -e

BOLD="\033[1m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
CYAN="\033[36m"
GRAY="\033[90m"
RESET="\033[0m"

echo ""
echo "${BOLD}${CYAN}  ╭──────────────────────────────────────╮${RESET}"
echo "${BOLD}${CYAN}  │   🚀 JioBase Self-Host Installer     │${RESET}"
echo "${BOLD}${CYAN}  ╰──────────────────────────────────────╯${RESET}"
echo ""

# --- Check for Node.js ---
check_node() {
  if command -v node >/dev/null 2>&1; then
    NODE_VERSION=$(node -v | sed 's/v//')
    NODE_MAJOR=$(echo "$NODE_VERSION" | cut -d. -f1)

    if [ "$NODE_MAJOR" -ge 18 ]; then
      echo "${GREEN}✓${RESET} Node.js v${NODE_VERSION} detected"
      return 0
    else
      echo "${YELLOW}!${RESET} Node.js v${NODE_VERSION} found, but v18+ is required"
      return 1
    fi
  else
    echo "${YELLOW}!${RESET} Node.js not found"
    return 1
  fi
}

# --- Install Node.js via fnm ---
install_node_fnm() {
  echo ""
  echo "${BOLD}Installing Node.js via fnm (Fast Node Manager)...${RESET}"
  echo "${GRAY}  fnm is a fast, cross-platform Node.js version manager${RESET}"
  echo ""

  # Check if fnm is already installed
  if ! command -v fnm >/dev/null 2>&1; then
    echo "  Installing fnm..."
    curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell

    # Add fnm to current session PATH
    FNM_DIR="$HOME/.local/share/fnm"
    if [ -d "$FNM_DIR" ]; then
      export PATH="$FNM_DIR:$PATH"
    fi

    # Also check common install locations
    if [ -d "$HOME/.fnm" ]; then
      export PATH="$HOME/.fnm:$PATH"
    fi

    # Source fnm env
    if command -v fnm >/dev/null 2>&1; then
      eval "$(fnm env)"
    else
      echo "${RED}✗${RESET} Failed to install fnm"
      echo ""
      echo "  Please install Node.js manually:"
      echo "  ${CYAN}https://nodejs.org/en/download${RESET}"
      echo ""
      exit 1
    fi
  fi

  echo "  Installing Node.js 18..."
  fnm install 18
  fnm use 18
  eval "$(fnm env)"

  # Verify
  if command -v node >/dev/null 2>&1; then
    echo "${GREEN}✓${RESET} Node.js $(node -v) installed"
  else
    echo "${RED}✗${RESET} Node.js installation failed"
    echo ""
    echo "  Please install Node.js manually:"
    echo "  ${CYAN}https://nodejs.org/en/download${RESET}"
    echo ""
    exit 1
  fi
}

# --- Check for npx ---
check_npx() {
  if command -v npx >/dev/null 2>&1; then
    return 0
  else
    echo "${RED}✗${RESET} npx not found (should come with Node.js)"
    echo "  Try reinstalling Node.js from: ${CYAN}https://nodejs.org${RESET}"
    exit 1
  fi
}

# --- Main ---
if check_node; then
  check_npx
  echo ""
  echo "${BOLD}Running create-jiobase...${RESET}"
  echo ""
  npx create-jiobase "$@"
else
  install_node_fnm
  check_npx
  echo ""
  echo "${BOLD}Running create-jiobase...${RESET}"
  echo ""
  npx create-jiobase "$@"
fi
